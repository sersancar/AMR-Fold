manifest {
  name        = 'amrfold-nextflow-singularity'
  author      = 'OpenAI for Sergio Sanchez'
  description = 'AMR-Fold inference pipeline with local conda profiles and SLURM Singularity support'
  version     = '0.6.1'
  mainScript  = 'main.nf'
}

params {
  input                   = null
  input_fasta             = null
  models_dir              = 'models'
  model_dir               = null
  outdir                  = 'results'

  chunk_size              = 256
  map_size_gb             = 8

  device                  = 'auto'
  half_precision          = true
  prostt5_dir             = null
  local_files_only        = false

  extract_batch_size      = 8
  extract_token_budget    = 4096
  extract_commit_every    = 100

  infer_batch_size        = 16
  num_workers             = 0

  bin_threshold           = 0.39917078614234924
  gate_classes            = 'multidrug,others,sulfonamide,rifamycin,quinolone'
  gate_tau                = 0.7108869316825098
  gate_delta              = 0.10345399260721301

  publish_intermediates   = false

  slurm_partition         = 'normal'
  slurm_gpu_partition     = 'gpu'
  slurm_account           = null
  slurm_extra             = null
  slurm_gpu_extra         = null
  gpus_per_task           = 1

  cpu_env_yaml            = "${projectDir}/envs/amrfold_infer_cpu.yml"
  gpu_env_yaml            = "${projectDir}/envs/amrfold_infer_gpu.yml"

  container_cpu           = null
  container_gpu           = null
  singularity_cache_dir   = null
  singularity_run_options = null
  singularity_auto_mounts = true

  local_light_cpus        = 1
  local_light_memory      = '2 GB'
  local_light_time        = '2h'

  local_extract_cpus      = 4
  local_extract_memory    = '24 GB'
  local_extract_time      = '72h'
  local_extract_maxForks  = 1

  local_score_cpus        = 4
  local_score_memory      = '16 GB'
  local_score_time        = '24h'
  local_score_maxForks    = 1

  cluster_light_cpus      = 1
  cluster_light_memory    = '2 GB'
  cluster_light_time      = '2h'

  cluster_extract_cpus    = 4
  cluster_extract_memory  = '48 GB'
  cluster_extract_time    = '72h'
  cluster_extract_maxForks = 8

  cluster_score_cpus      = 4
  cluster_score_memory    = '32 GB'
  cluster_score_time      = '24h'
  cluster_score_maxForks  = 8

  use_gpu_lock            = false
  max_gpu_tasks           = null
}

process {
  executor      = 'local'
  errorStrategy = 'terminate'

  withLabel: light {
    cpus   = params.local_light_cpus
    memory = params.local_light_memory
    time   = params.local_light_time
  }

  withLabel: extract {
    cpus     = params.local_extract_cpus
    memory   = params.local_extract_memory
    time     = params.local_extract_time
    maxForks = params.local_extract_maxForks
  }

  withLabel: score {
    cpus     = params.local_score_cpus
    memory   = params.local_score_memory
    time     = params.local_score_time
    maxForks = params.local_score_maxForks
  }
}

conda {
  enabled  = false
  cacheDir = "${projectDir}/.nf-conda"
}

singularity {
  enabled    = false
  autoMounts = params.singularity_auto_mounts
  cacheDir   = params.singularity_cache_dir ?: "${projectDir}/.singularity-cache"
  runOptions = params.singularity_run_options ?: ''
}

report   { overwrite = true }
timeline { overwrite = true }
trace    { overwrite = true }

String detectVisibleGpuCount() {
  try {
    def proc = ['bash','-lc','if command -v nvidia-smi >/dev/null 2>&1; then nvidia-smi -L | wc -l; else echo 0; fi'].execute()
    proc.waitFor()
    def txt = proc.in.text.trim()
    return txt ?: '0'
  }
  catch(Exception e) {
    return '0'
  }
}

def visibleGpuCount = (detectVisibleGpuCount() as Integer)
def localGpuTaskCount = params.max_gpu_tasks ? (params.max_gpu_tasks as Integer) : Math.max(1, visibleGpuCount)
def accountOpt = params.slurm_account ? "--account=${params.slurm_account}" : ''
def slurmExtra = params.slurm_extra ?: ''
def gpuOpt = "--gres=gpu:${params.gpus_per_task}"
def slurmGpuExtra = params.slurm_gpu_extra ?: ''

def baseClusterOptions = [accountOpt, slurmExtra].findAll { it?.trim() }.join(' ')
def gpuClusterOptions  = [accountOpt, gpuOpt, slurmGpuExtra].findAll { it?.trim() }.join(' ')

def useCpuContainer = params.container_cpu ? true : false
def useGpuContainer = params.container_gpu ? true : false

profiles {
  standard {
    process.executor = 'local'
  }

  conda {
    conda.enabled    = true
    process.executor = 'local'
    process.conda    = params.cpu_env_yaml
    params.device    = 'cpu'
    params.use_gpu_lock = false

    process {
      withLabel: light {
        conda  = params.cpu_env_yaml
        cpus   = params.local_light_cpus
        memory = params.local_light_memory
        time   = params.local_light_time
      }
      withLabel: extract {
        conda    = params.cpu_env_yaml
        cpus     = params.local_extract_cpus
        memory   = params.local_extract_memory
        time     = params.local_extract_time
        maxForks = params.local_extract_maxForks
      }
      withLabel: score {
        conda    = params.cpu_env_yaml
        cpus     = params.local_score_cpus
        memory   = params.local_score_memory
        time     = params.local_score_time
        maxForks = params.local_score_maxForks
      }
    }
  }

  conda_gpu {
    conda.enabled    = true
    process.executor = 'local'
    params.device    = 'cuda'
    params.use_gpu_lock = true

    process {
      withLabel: light {
        conda  = params.cpu_env_yaml
        cpus   = params.local_light_cpus
        memory = params.local_light_memory
        time   = params.local_light_time
      }
      withLabel: extract {
        conda    = params.gpu_env_yaml
        cpus     = params.local_extract_cpus
        memory   = params.local_extract_memory
        time     = params.local_extract_time
        maxForks = localGpuTaskCount
      }
      withLabel: score {
        conda    = params.gpu_env_yaml
        cpus     = params.local_score_cpus
        memory   = params.local_score_memory
        time     = params.local_score_time
        maxForks = localGpuTaskCount
      }
    }
  }

  slurm {
    process.executor       = 'slurm'
    process.queue          = params.slurm_partition
    process.clusterOptions = baseClusterOptions
    params.device          = 'cpu'
    params.use_gpu_lock    = false

    conda.enabled       = !useCpuContainer
    singularity.enabled = useCpuContainer

    process {
      withLabel: light {
        cpus      = params.cluster_light_cpus
        memory    = params.cluster_light_memory
        time      = params.cluster_light_time
        conda     = useCpuContainer ? null : params.cpu_env_yaml
        container = null
      }
      withLabel: extract {
        cpus      = params.cluster_extract_cpus
        memory    = params.cluster_extract_memory
        time      = params.cluster_extract_time
        maxForks  = params.cluster_extract_maxForks
        conda     = useCpuContainer ? null : params.cpu_env_yaml
        container = useCpuContainer ? params.container_cpu : null
      }
      withLabel: score {
        cpus      = params.cluster_score_cpus
        memory    = params.cluster_score_memory
        time      = params.cluster_score_time
        maxForks  = params.cluster_score_maxForks
        conda     = useCpuContainer ? null : params.cpu_env_yaml
        container = useCpuContainer ? params.container_cpu : null
      }
    }
  }

  slurm_gpu {
    process.executor       = 'slurm'
    process.queue          = params.slurm_partition
    process.clusterOptions = baseClusterOptions
    params.device          = 'cuda'
    params.use_gpu_lock    = false

    conda.enabled       = !useGpuContainer
    singularity.enabled = useGpuContainer

    process {
      withLabel: light {
        cpus      = params.cluster_light_cpus
        memory    = params.cluster_light_memory
        time      = params.cluster_light_time
        conda     = useGpuContainer ? null : params.cpu_env_yaml
        container = null
      }
      withLabel: extract {
        queue            = params.slurm_gpu_partition
        cpus             = params.cluster_extract_cpus
        memory           = params.cluster_extract_memory
        time             = params.cluster_extract_time
        maxForks         = params.cluster_extract_maxForks
        clusterOptions   = gpuClusterOptions
        conda            = useGpuContainer ? null : params.gpu_env_yaml
        container        = useGpuContainer ? params.container_gpu : null
        containerOptions = useGpuContainer ? '--nv' : null
      }
      withLabel: score {
        queue            = params.slurm_gpu_partition
        cpus             = params.cluster_score_cpus
        memory           = params.cluster_score_memory
        time             = params.cluster_score_time
        maxForks         = params.cluster_score_maxForks
        clusterOptions   = gpuClusterOptions
        conda            = useGpuContainer ? null : params.gpu_env_yaml
        container        = useGpuContainer ? params.container_gpu : null
        containerOptions = useGpuContainer ? '--nv' : null
      }
    }
  }
}
